# === Aplicação ===
ENV=development

# === Banco de Dados (PostgreSQL) ===
DATABASE_URL=postgresql://postgres:postgres@db:5432/cnpj
POSTGRES_DB=cnpj
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# === Object Storage (Garage S3) ===
S3_ENDPOINT_URL=http://storage:3900
S3_ACCESS_KEY=GK000000000000000000000000
S3_SECRET_KEY=minioadmin_secretkey
S3_BUCKET_NAME=cnpj-data

# Garage Environment Variables (para o container do storage)
GARAGE_ALLOW_WORLD_READABLE_TEMPFILES=true
GARAGE_DEFAULT_ACCESS_KEY=GK000000000000000000000000
GARAGE_DEFAULT_SECRET_KEY=minioadmin_secretkey
GARAGE_DEFAULT_BUCKET=cnpj-data

# === Receita Federal ===
RECEITA_BASE_URL=https://arquivos.receitafederal.gov.br/index.php/s/YggdBLfdninEJX9

# === Diretórios Internos do Container ===
# Usamos /tmp para evitar problemas de permissão (Permission denied) 
# ao usar volumes montados da máquina host em containers rootless.
DATA_RAW_DIR=/tmp/data/raw
DATA_PROCESSED_DIR=/tmp/data/processed
