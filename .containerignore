# .containerignore
# Impede que arquivos desnecessários entrem na imagem durante o podman build.
# Reduz tamanho da imagem, melhora velocidade de build e evita vazamento de credenciais.

.git/
.gitignore

# Ambientes virtuais
venv/
ENV/
env/

# Caches e artefatos Python
__pycache__/
*.py[cod]
*$py.class
*.so

# IDEs e configurações locais
.vscode/
.idea/
.env

# Dados brutos e processados — NÃO devem entrar na imagem
data/
*.csv
*.parquet
*.zip
*.sqlite

# Documentação e ADRs (não necessários no runtime)
docs/
README.md
Makefile
